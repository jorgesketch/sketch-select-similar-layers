var debugMode = false;
var itemsMatched = 0;

var debugLog = function(msg) {
  if (debugMode) {
    log(msg);
  }
}

// Select in Group

var selectSameFillInGroup = function(context) {
  selectSameFill(context, "group");
}

var selectSameBorderInGroup = function(context) {
  selectSameBorder(context, "group");
}

var selectSameBorderThicknessInGroup = function(context) {
  selectSameBorderThickness(context, "group");
}

var selectSameFontInGroup = function(context) {
  selectSameFont(context, "group");
}

var selectSameFontAndColorInGroup = function(context) {
  selectSameFontAndColor(context, "group");
}

var selectSameOpacityInGroup = function(context) {
  selectSameOpacity(context, "group");
}

var selectSameBlendModeInGroup = function(context) {
  selectSameBlendMode(context, "group");
}

var selectSameLayerNameInGroup = function(context) {
  selectSameLayerName(context, "group");
}

var selectSameLayerNameAndClassInGroup = function(context) {
  selectSameLayerNameAndClass(context, "group");
}

var selectSameLayerClassInGroup = function(context) {
  selectSameLayerClass(context, "group");
}

var selectSameSymbolInGroup = function(context) {
  selectSameSymbol(context, "group");
}

// Select in Page

