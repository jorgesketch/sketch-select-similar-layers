}

var selectSameOpacity = function(context, where) {
  if (typeof where === "undefined") where = "artboard";
  var selectedLayer = context.selection.firstObject();

  if(!selectionErrorHandling(context, true)) return;

  iterateThroughLayers(context, selectedLayer, selectIfSameOpacity, where);
}

