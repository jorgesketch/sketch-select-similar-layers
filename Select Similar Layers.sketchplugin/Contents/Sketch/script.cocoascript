  selectSameFill(context, "page");
}

var selectSameBorderInPage = function(context) {
  selectSameBorder(context, "page");
}

var selectSameBorderThicknessInPage = function(context) {
  selectSameBorderThickness(context, "page");
}

var selectSameFontInPage = function(context) {
  selectSameFont(context, "page");
}

var selectSameFontAndColorInPage = function(context) {
  selectSameFontAndColor(context, "page");
}

var selectSameOpacityInPage = function(context) {
  selectSameOpacity(context, "page");
}

var selectSameBlendModeInPage = function(context) {
  selectSameBlendMode(context, "page");
}

var selectSameLayerNameInPage = function(context) {
  selectSameLayerName(context, "page");
}

var selectSameLayerNameAndClassInPage = function(context) {
  selectSameLayerNameAndClass(context, "page");
}

var selectSameLayerClassInPage = function(context) {
  selectSameLayerClass(context, "page");
}

var selectSameSymbolInPage = function(context) {
  selectSameSymbol(context, "page");
}

var selectSameSymbol = function(context, where) {
  if (typeof where === "undefined") where = "artboard";
  if(!selectionErrorHandling(context, false)) return;

  var selectedLayer = context.selection.firstObject();

  if ([selectedLayer class] != MSSymbolInstance) {
    showAlert("Not a symbol instance", "Please select a symbol instance and try again.");
    return;
  }

  iterateThroughLayers(context, selectedLayer, selectIfSameSymbol, where);
}

var selectSameFill = function(context, where) {
  if (typeof where === "undefined") where = "artboard";
  if(!selectionErrorHandling(context, false)) return;

  var selectedLayer = context.selection.firstObject();
  var fill = firstVisibleFill(selectedLayer);

  if(!fill) {
    showAlert("No visible fills", "Please select a layer with at least one fill and try again.");
    return;
  }

  iterateThroughLayers(context, selectedLayer, selectIfSameFill, where);
}

var selectSameBorder = function(context, where) {
  if (typeof where === "undefined") where = "artboard";
  if(!selectionErrorHandling(context, false)) return;

  var selectedLayer = context.selection.firstObject();
  var border = firstVisibleBorder(selectedLayer);

  if(!border) {
    showAlert("No visible borders", "Please select a layer with at least one border and try again.");
    return;
  }

  iterateThroughLayers(context, selectedLayer, selectIfSameBorder, where);
}

var selectSameBorderThickness = function(context, where) {
  if (typeof where === "undefined") where = "artboard";
  if(!selectionErrorHandling(context, false)) return;

  var selectedLayer = context.selection.firstObject();
  var border = firstVisibleBorder(selectedLayer);

  if(!border) {
    showAlert("No visible borders", "Please select a layer with at least one border and try again.");
